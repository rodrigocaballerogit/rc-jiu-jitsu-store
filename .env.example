# Anthropic API key — get yours at https://console.anthropic.com
#
# This key is SERVER-SIDE ONLY. It is read by the /api/chat Cloudflare Pages
# Function (functions/api/chat.ts) and is NEVER bundled into the browser.
# Do NOT prefix it with VITE_ (that would expose it client-side).
#
# Local dev (wrangler pages dev): create a .dev.vars file with this line.
# Production: add it in Cloudflare Pages → Settings → Environment Variables.
ANTHROPIC_API_KEY=your_anthropic_api_key_here
